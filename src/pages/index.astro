  type Lang = 'es' | 'en';
  let lang: Lang = (localStorage.getItem('lang') as Lang) || 'es';
  let typingPhrases: string[] = T[lang]['hero.typing'] as string[];

  document.documentElement.setAttribute('data-lang', lang);
  setLangBtn(lang);

  function setLangBtn(l: Lang) {
    const btn = document.getElementById('langToggle');
    if (btn) btn.textContent = l === 'es' ? 'EN' : 'ES';
  }

  function applyLang(l: Lang) {
    const dict = T[l];
    document.querySelectorAll('[data-i18n], [data-i18n-placeholder]').forEach(el => el.classList.add('lang-fade'));
    setTimeout(() => {
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n')!;
        const val = dict[key];
        if (typeof val === 'string') el.textContent = val;
      });
      document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
        const key = el.getAttribute('data-i18n-placeholder')!;
        const val = dict[key];
        if (typeof val === 'string') (el as HTMLInputElement).placeholder = val;
      });
      document.querySelectorAll('[data-i18n-nav]').forEach(el => {
        const key = el.getAttribute('data-i18n-nav')!;
        const val = dict[key];
        if (typeof val === 'string') el.textContent = val;
      });
      document.documentElement.setAttribute('lang', l);
      document.documentElement.setAttribute('data-lang', l);
      typingPhrases = dict['hero.typing'] as string[];
      restartTyping();
      document.querySelectorAll('[data-i18n], [data-i18n-placeholder]').forEach(el => el.classList.remove('lang-fade'));
    }, 200);
  }

  document.getElementById('langToggle')?.addEventListener('click', () => {
    lang = lang === 'es' ? 'en' : 'es';
    localStorage.setItem('lang', lang);
    setLangBtn(lang);
    applyLang(lang);
  });

  /* ══ TYPING ══ */
  const typingEl = document.getElementById('typingText');
  let pIdx = 0, cIdx = 0, deleting = false, paused = false;
  let tTimer: ReturnType<typeof setTimeout> | null = null;

  function tick() {
    if (!typingEl || paused) return;
    const cur = typingPhrases[pIdx % typingPhrases.length];
    if (!deleting) {
      typingEl.textContent = cur.slice(0, ++cIdx);
      if (cIdx === cur.length) { paused = true; tTimer = setTimeout(() => { deleting = true; paused = false; tick(); }, 1800); return; }
      tTimer = setTimeout(tick, 55);
    } else {
      typingEl.textContent = cur.slice(0, --cIdx);
      if (cIdx === 0) { deleting = false; pIdx = (pIdx + 1) % typingPhrases.length; paused = true; tTimer = setTimeout(() => { paused = false; tick(); }, 400); return; }
      tTimer = setTimeout(tick, 30);
    }
  }

  function restartTyping() {
    if (tTimer) clearTimeout(tTimer);
    if (typingEl) typingEl.textContent = '';
    pIdx = 0; cIdx = 0; deleting = false; paused = false;
    tTimer = setTimeout(tick, 300);
  }

  setTimeout(tick, 900);

  /* ══ SKILL BARS — animate on scroll ══ */
